generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    Int       @id @default(autoincrement())
  telegramId            BigInt    @unique
  username              String?
  firstName             String
  lastName              String?
  createdAt             DateTime  @default(now())
  subscriptionExpiresAt DateTime?
  isAdmin               Boolean   @default(false)
  filterGeoLat          Decimal?  @db.Decimal(10, 7)
  filterGeoLng          Decimal?  @db.Decimal(10, 7)
  filterGeoRadiusKm     Int?
  filterEquipIds        Int[]     @default([])
  requests              Request[]
  contactViews          ContactView[]
}

model EquipmentType {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  icon            String
  rentals         Rental[]
  transportations Transportation[]
}

model Request {
  id               Int             @id @default(autoincrement())
  type             RequestType
  paymentType      PaymentType
  status           RequestStatus   @default(PENDING)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  userId           Int
  user             User            @relation(fields: [userId], references: [id])
  rental           Rental?
  transportation   Transportation?
  delivery         Delivery?
  contactPhone     String?
  contactTelegram  String?
  contactWhatsapp  String?
  contactViews     ContactView[]
}

model Rental {
  id              Int           @id @default(autoincrement())
  requestId       Int           @unique
  request         Request       @relation(fields: [requestId], references: [id], onDelete: Cascade)
  equipmentTypeId Int
  equipmentType   EquipmentType @relation(fields: [equipmentTypeId], references: [id])
  address         String
  lat             Decimal?      @db.Decimal(10, 7)
  lng             Decimal?      @db.Decimal(10, 7)
  startsAt        DateTime
  durationDays    Int
}

model Transportation {
  id              Int           @id @default(autoincrement())
  requestId       Int           @unique
  request         Request       @relation(fields: [requestId], references: [id], onDelete: Cascade)
  equipmentTypeId Int
  equipmentType   EquipmentType @relation(fields: [equipmentTypeId], references: [id])
  cargo           String
  fromAddress     String
  fromLat         Decimal?      @db.Decimal(10, 7)
  fromLng         Decimal?      @db.Decimal(10, 7)
  toAddress       String
  toLat           Decimal?      @db.Decimal(10, 7)
  toLng           Decimal?      @db.Decimal(10, 7)
  startsAt        DateTime
  ratePerHour     Decimal       @db.Decimal(10, 2)
}

model Delivery {
  id        Int      @id @default(autoincrement())
  requestId Int      @unique
  request   Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  cargo     String
  toAddress String
  toLat     Decimal? @db.Decimal(10, 7)
  toLng     Decimal? @db.Decimal(10, 7)
  startsAt  DateTime
  volume    String
}

model ContactView {
  id        Int      @id @default(autoincrement())
  userId    Int
  requestId Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  request   Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@unique([userId, requestId])
}

model AppSettings {
  id         Int    @id @default(1)
  termsUrl   String @default("")
  privacyUrl String @default("")
}

model HelpFaq {
  id       Int    @id @default(autoincrement())
  question String
  answer   String
  order    Int    @default(0)
}

model HelpContact {
  id    Int    @id @default(autoincrement())
  label String
  type  String
  value String
  url   String
  order Int    @default(0)
}

enum RequestType {
  RENTAL
  TRANSPORTATION
  DELIVERY
}

enum PaymentType {
  CASH
  NON_CASH
}

enum RequestStatus {
  PENDING
  PUBLISHED
  IN_PROGRESS
  DONE
  CANCELLED
}
